# ====================================================================
# FluencyTides 環境變數配置範例
# 
# 複製此檔案為 `.env` 並填寫對應的敏感資訊。
# 所有的環境變數均由 `backend/app/core/config.py` 中的 Settings 管理。
# ====================================================================

# --------------------------------------------------------------------
# 應用程式基礎設定
# --------------------------------------------------------------------
# 專案名稱 (可選)
PROJECT_NAME=FluencyTides
# 系統日誌層級 (可選，DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
# API 認證金鑰 (可選，留空或不設代表開發模式跳過認證)
API_SECRET_KEY=your_api_secret_key_here

# --------------------------------------------------------------------
# 資料庫設定 (SQLModel + SQLAlchemy Async)
# --------------------------------------------------------------------
# 資料庫連線字串 (可選，預設使用 SQLite，適合開發與單人使用)
DATABASE_URL=sqlite+aiosqlite:///./fluencytides.db
# 遷移 MySQL（適合生產環境與多人併發）：
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/fluencytides

# --------------------------------------------------------------------
# AnkiConnect 設定
# --------------------------------------------------------------------
# AnkiConnect 本地或遠端端點 URL (可選)
ANKI_CONNECT_URL=http://127.0.0.1:8765
# AnkiConnect API 金鑰 (可選)
ANKI_CONNECT_API_KEY=your_ankiconnect_api_key_here

# --------------------------------------------------------------------
# Cloudflare Access 設定 (用於遠端 AnkiConnect 穿透，可選)
# --------------------------------------------------------------------
# Cloudflare Access Client ID (可選)
CF_ACCESS_CLIENT_ID=your_cloudflare_client_id.access
# Cloudflare Access Client Secret (可選)
CF_ACCESS_CLIENT_SECRET=your_cloudflare_client_secret

# --------------------------------------------------------------------
# MinIO 物件存儲設定
# --------------------------------------------------------------------
# MinIO 伺服器主機位址 (可選)
MINIO_HOST=127.0.0.1
# MinIO 伺服器埠號 (可選)
MINIO_PORT=9000
# MinIO 存取金鑰 (可選)
MINIO_ACCESS_KEY=minioadmin
# MinIO 秘密金鑰 (可選)
MINIO_SECRET_KEY=minioadmin
# 是否使用 HTTPS 連線 MinIO (可選)
MINIO_SECURE=False
# MinIO 預設儲存桶名稱 (可選)
MINIO_DEFAULT_BUCKET=fluencytides-media

# --------------------------------------------------------------------
# Telegram Bot 設定 (Phase 3)
# --------------------------------------------------------------------
# Telegram Bot Token (可選，向 @BotFather 取得)
TG_BOT_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ
# Telegram Bot 使用者名稱 (可選，例如: XXX_bot，用於生成 Deep Link)
TG_BOT_USERNAME=XXX_bot
# 允許使用的 User ID 列表 (可選，逗號分隔，避免他人盜刷 LLM 額度)
TG_ALLOWED_USER_IDS=123456789,987654321
# 生產環境 Webhook 網域名稱 (可選，若留空則預設使用 Long Polling)
TG_WEBHOOK_DOMAIN=https://your-domain.com
# Webhook 接收路徑 (可選)
TG_WEBHOOK_PATH=/api/webhook
# Telegram 預設卡片生成設定 (可選)
TG_DEFAULT_DECK=Default
# Telegram 預設生成使用的模型名稱 (可選)
TG_DEFAULT_MODEL_NAME=TOEIC_Coach_Dark
# Telegram 預設生成使用的模型 JSON 檔名 (可選)
TG_DEFAULT_MODEL_FILE=TOEIC_Coach_Dark.json
# Telegram 兩階段互動狀態過期時間 (分鐘) (可選)
TG_STATE_EXPIRE_MINUTES=5

# --------------------------------------------------------------------
# LLM (OpenAI 相容) 設定
# --------------------------------------------------------------------
# OpenAI / Gemini 相容 API 金鑰 (可選)
LLM_API_KEY=your_llm_api_key_here
# OpenAI / Gemini 相容 API 端點 URL (可選)
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM 預設模型名稱 (可選)
LLM_MODEL_NAME=gemini-2.0-flash

# --------------------------------------------------------------------
# Audio Evaluator 語音評分設定 (Strategy Pattern)
# --------------------------------------------------------------------
# 語音評分器的供應商選擇: 'openai' 或 'gemini_native' (可選)
AUDIO_EVALUATOR_PROVIDER=gemini_native
# Google Gemini 原生 SDK API Key (可選，當 AUDIO_EVALUATOR_PROVIDER='gemini_native' 時需要)
GEMINI_NATIVE_API_KEY=your_gemini_native_api_key_here
# Gemini 原生 SDK 使用的模型名稱 (可選)
GEMINI_NATIVE_MODEL=gemini-2.5-flash

# --------------------------------------------------------------------
# VOICEPEAK 語音合成設定
# --------------------------------------------------------------------
# VOICEPEAK CLI 執行檔的完整路徑或命令名稱 (可選)
VOICEPEAK_EXECUTABLE_PATH=voicepeak
# VOICEPEAK 預設旁白角色名稱 (CLI 英文 ID) (可選)
VOICEPEAK_DEFAULT_NARRATOR=Japanese Male Child
# 角色設定 JSON 檔案路徑 (可選)
VOICEPEAK_CHARACTERS_CONFIG_PATH=characters.json
