{
  "modelName": "TOEIC_Coach_Dark_v2",
  "inOrderFields": [
    "Expression",
    "Word_Audio",
    "Target_Example_Sentence",
    "Target_Example_Japanese",
    "Target_Example_Audio",
    "Target_Phonetic",
    "Target_POS",
    "Target_Translation",
    "Target_Nuance",
    "Target_Example_Translation",
    "Chunking",
    "Word_Family_JSON",
    "Synonyms_JSON",
    "Collocations_JSON"
  ],
  "llm_schema": {
    "type": "object",
    "properties": {
      "Expression": {
        "type": "string",
        "description": "必須完全使用使用者提供的原始目標單字或片語，一字不漏地原樣輸出，絕對不可以自己造句或加上解說。"
      },
      "Target_Phonetic": {
        "type": "string",
        "description": "目標單字的音標（如：/əˈkseləreɪt/）。"
      },
      "Target_POS": {
        "type": "string",
        "enum": ["n.", "vi.", "vt.", "phrasal v.", "adj.", "adv.", "prep.", "conj.", "pron.", "det.", "interj.", "phrase"],
        "description": "目標單字的詞性縮寫。必須嚴格遵循小寫並以點號結尾。僅限從列舉值中選擇。"
      },
      "Target_Translation": {
        "type": "string",
        "description": "目標單字的繁體中文翻譯。"
      },
      "Target_Nuance": {
        "type": "string",
        "description": "母語者使用此單字的語感、語境或用法微差異。"
      },
      "Target_Example_Translation": {
        "type": "string",
        "description": "為使用者提供的情境例句進行繁體中文翻譯。如果使用者沒有提供例句，則根據該單字造一個多益情境例句並提供中文翻譯。"
      },
      "Word_Audio": {
        "type": "string",
        "description": "單字音頻佔位符 (請原樣保留或留空，因為這是由使用者手動提供的非LLM生成欄位)。"
      },
      "Target_Example_Audio": {
        "type": "string",
        "description": "目標例句音頻佔位符 (請原樣保留或留空，因為這是由使用者手動提供的非LLM生成欄位)。"
      },
      "Chunking": {
        "type": "string",
        "description": "先給出單字或句子的繁體中文翻譯。如果語塊中包含多益值得學習的單字，需簡潔補充「字根拆解」或「記憶法」。"
      },
      "Word_Family_JSON": {
        "type": "array",
        "description": "存放同字根的詞性家族（如：Electronic, Electronics...）。必須為 JSON Array 格式。請特別注意：如果目標單字具有『其他詞性』的用法（例如名詞與動詞同拼字），你仍必須將其他詞性的用法列入家族中。僅排除與本卡片核心例句完全『同拼字且同詞性』的冗餘收錄！",
        "items": {
          "type": "object",
          "properties": {
            "word": {
              "type": "string",
              "description": "單字"
            },
            "phonetic": {
              "type": "string",
              "description": "音標"
            },
            "pos": {
              "type": "string",
              "enum": ["n.", "vi.", "vt.", "phrasal v.", "adj.", "adv.", "prep.", "conj.", "pron.", "det.", "interj."],
              "description": "詞性縮寫。必須嚴格遵循小寫並以點號結尾。僅限從列舉值中選擇，嚴禁輸出單字全寫（例如：必須使用 n. 而非 Noun）。"
            },
            "translation": {
              "type": "string",
              "description": "中文翻譯"
            },
            "nuance": {
              "type": "string",
              "description": "母語者語感/用法微差異"
            },
            "example": {
              "type": "string",
              "description": "多益情境例句"
            },
            "example_translation": {
              "type": "string",
              "description": "例句繁體中文翻譯"
            }
          },
          "required": [
            "word",
            "phonetic",
            "pos",
            "translation",
            "nuance",
            "example",
            "example_translation"
          ],
          "additionalProperties": false
        }
      },
      "Synonyms_JSON": {
        "type": "array",
        "description": "存放近義詞或易混淆詞的對比（如：Indicate, Suggest...）。必須為 JSON Array 格式。",
        "items": {
          "type": "object",
          "properties": {
            "word": {
              "type": "string",
              "description": "單字"
            },
            "phonetic": {
              "type": "string",
              "description": "音標"
            },
            "pos": {
              "type": "string",
              "description": "詞性"
            },
            "translation": {
              "type": "string",
              "description": "中文意"
            },
            "nuance": {
              "type": "string",
              "description": "母語者語感/用法微差異"
            },
            "example": {
              "type": "string",
              "description": "多益情境例句"
            },
            "example_translation": {
              "type": "string",
              "description": "例句繁體中文翻譯"
            }
          },
          "required": [
            "word",
            "phonetic",
            "pos",
            "translation",
            "nuance",
            "example",
            "example_translation"
          ],
          "additionalProperties": false
        }
      },
      "Collocations_JSON": {
        "type": "array",
        "description": "必考搭配詞 (Collocations)：請列出常用搭配或固定用法。數量不限（若無可留空），請將英文搭配與中文翻譯分開提供，必須為 JSON Array 格式。",
        "items": {
          "type": "object",
          "properties": {
            "en": {
              "type": "string",
              "description": "英文搭配詞"
            },
            "tw": {
              "type": "string",
              "description": "繁體中文翻譯"
            }
          },
          "required": ["en", "tw"],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "Expression",
      "Word_Audio",
      "Target_Phonetic",
      "Target_POS",
      "Target_Translation",
      "Target_Nuance",
      "Target_Example_Translation",
      "Target_Example_Audio",
      "Chunking",
      "Word_Family_JSON",
      "Synonyms_JSON",
      "Collocations_JSON"
    ],
    "additionalProperties": false
  }
}