{
  "modelName": "Contrast_Coach_Dark",
  "inOrderFields": [
    "Topic",
    "Native_Language",
    "Target_Language",
    "My_Reply",
    "Correct_Reply",
    "Analysis",
    "Expressions_JSON"
  ],
  "llm_schema": {
    "type": "object",
    "properties": {
      "Analysis": {
        "type": "string",
        "description": "分析使用者的表達盲點（如語法錯誤、母語者聽了會有歧義或是感覺不好等），然後簡單總結修正點。"
      },
      "Expressions_JSON": {
        "type": "array",
        "description": "總結需要記住的表達與修改重點。數量必須根據實際需求浮動（0到10個）。必須為 JSON Array 格式。",
        "items": {
          "type": "object",
          "properties": {
            "expression": {
              "type": "string",
              "description": "表達或正確的回覆句子（可以列舉相關表達，未必要完全在正確版本例句裡面）"
            },
            "explanation": {
              "type": "string",
              "description": "對應的解釋與母語者視角的點評（這是卡片最重要的部分）"
            }
          },
          "required": [
            "expression",
            "explanation"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "Analysis",
      "Expressions_JSON"
    ],
    "additionalProperties": false
  }
}
