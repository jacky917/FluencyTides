# =========================
# Frontend .dockerignore
# =========================

# 1. 避免本機的 node_modules 蓋掉容器內的安裝
node_modules/

# 2. 避免把本機建置好的舊檔案包進去
dist/
dist-ssr/
*.tsbuildinfo

# 3. 作業系統與編輯器設定
.vscode/
.idea/
.DS_Store
Thumbs.db

# 4. 環境變數與機密金鑰
.env
.env.*
!.env.example

# 5. 日誌
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 6. Git 與 GitHub (機密防漏)
.git/
.gitignore
.github/

# 7. 後端相關
backend/
