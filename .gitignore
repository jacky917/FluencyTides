# =========================
# FluencyTides .gitignore
# =========================

# -------------------------
# Environment Variables & Secrets
# -------------------------
.env
.env.*
!.env.example
*.pem
*.key

# -------------------------
# Python / Backend
# -------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
!frontend/src/lib/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
.venv/
env/
.env_venv/
ENV/
env.bak/
venv.bak/

# Database
*.db
*.sqlite3

# Test / Coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.swn
*.swo
*.swp
.pytest_cache/
htmlcov/

# -------------------------
# Node / Frontend (React + Vite)
# -------------------------
node_modules/
frontend/dist/
frontend/dist-ssr/
*.local
.npm/

# Vite specific
.eslintcache
*.tsbuildinfo

# -------------------------
# IDE / OS / Editor
# -------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -------------------------
# Logs & Agent
# -------------------------
*.log
.agent/
memo/
old/
